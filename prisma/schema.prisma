generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum EnergyClass {
  A
  B
  C
  D
  E
  F
  G
}

enum ExpenseCategory {
  HEATING
  COLD_WATER
  HOT_WATER
  WASTEWATER
  WASTE
  CLEANING
  REPAIR_FUND
  ADMINISTRATION
  ELEVATOR
  OTHER
}

enum UserRole {
  OWNER
  ASSOCIATION_ADMIN
  CONTRACTOR
  PLATFORM_ADMIN
}

enum Language {
  LV
  RU
}

enum ReportStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum VoteDecision {
  YES
  NO
  ABSTAIN
}

enum AuthMethod {
  SMART_ID
  EPARAKSTS
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  INITIATED
  VOTING
  CONTRACTED
  IN_PROGRESS
  COMPLETED
}

// ─── MODELS ───────────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  phone             String?
  fullName          String   @default("")
  role              UserRole @default(OWNER)
  smartIdCode       String?
  preferredLanguage Language @default(LV)
  createdAt         DateTime @default(now())

  apartments      Apartment[]
  votes           Vote[]
  uploadedReports ExpenseReport[]

  // NextAuth required fields
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Building {
  id               String       @id @default(uuid())
  address          String
  cadastralCode    String       @unique
  vzdId            String?      @unique
  series           String?
  constructionYear Int?
  totalAreaM2      Decimal?
  apartmentCount   Int?
  floorCount       Int?
  wallMaterial     String?
  energyClass      EnergyClass?
  district         String?
  lat              Decimal?
  lon              Decimal?
  vzdUpdatedAt     DateTime?
  bvkbUpdatedAt    DateTime?
  createdAt        DateTime     @default(now())

  apartments Apartment[]
  reports    ExpenseReport[]
  campaigns  VotingCampaign[]
  projects   RenovationProject[]

  @@index([district])
  @@index([series])
  @@index([energyClass])
  @@index([constructionYear])
  @@index([wallMaterial])
}

model Apartment {
  id              String   @id @default(uuid())
  buildingId      String
  apartmentNumber String
  areaM2          Decimal
  ownerId         String?
  ownershipShare  Decimal
  zemesgramataRef String?

  building Building  @relation(fields: [buildingId], references: [id])
  owner    User?     @relation(fields: [ownerId], references: [id])
  votes    Vote[]

  @@unique([buildingId, apartmentNumber])
}

model ExpenseReport {
  id          String       @id @default(uuid())
  buildingId  String
  periodYear  Int
  periodMonth Int
  rawFileKey  String
  parsedData  Json?
  status      ReportStatus @default(PENDING)
  uploadedBy  String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())

  building Building      @relation(fields: [buildingId], references: [id])
  uploader User?         @relation(fields: [uploadedBy], references: [id])
  items    ExpenseItem[]

  @@unique([buildingId, periodYear, periodMonth])
  @@index([buildingId])
}

model ExpenseItem {
  id           String          @id @default(uuid())
  reportId     String
  category     ExpenseCategory
  rawLabel     String
  amountTotal  Decimal
  amountPerM2  Decimal
  amountPerApt Decimal
  unit         String?

  report ExpenseReport @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([category])
}

model BenchmarkSegment {
  id            String          @id @default(uuid())
  series        String
  district      String
  areaRange     String
  category      ExpenseCategory
  periodYear    Int
  periodMonth   Int
  buildingCount Int
  p25           Decimal
  p50           Decimal
  p75           Decimal
  computedAt    DateTime        @default(now())

  @@unique([series, district, areaRange, category, periodYear, periodMonth])
}

model VotingCampaign {
  id                String         @id @default(uuid())
  buildingId        String
  title             String
  description       String?
  status            CampaignStatus @default(DRAFT)
  requiredThreshold Decimal        @default(0.50)
  currentYesShare   Decimal        @default(0)
  deadline          DateTime?
  protocolKey       String?
  createdAt         DateTime       @default(now())

  building Building            @relation(fields: [buildingId], references: [id])
  votes    Vote[]
  projects RenovationProject[]

  @@index([buildingId])
}

model Vote {
  id             String       @id @default(uuid())
  campaignId     String
  apartmentId    String
  ownerId        String
  decision       VoteDecision
  ownershipShare Decimal
  signature      String
  signedAt       DateTime
  authMethod     AuthMethod

  campaign  VotingCampaign @relation(fields: [campaignId], references: [id])
  apartment Apartment      @relation(fields: [apartmentId], references: [id])
  owner     User           @relation(fields: [ownerId], references: [id])

  @@unique([campaignId, apartmentId])
  @@index([campaignId])
}

model Contractor {
  id                 String   @id @default(uuid())
  userId             String   @unique
  companyName        String
  registrationNumber String   @unique
  luroftVerified     Boolean  @default(false)
  specializations    String[]
  geographicCoverage String[]
  rating             Decimal?
  ratingCount        Int      @default(0)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  projects RenovationProject[]
}

model BlogPost {
  id          String   @id @default(uuid())
  slug        String
  locale      String
  title       String
  description String
  content     String   @db.Text
  publishedAt DateTime
  readMinutes Int
  tags        String[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, published])
}

model RenovationProject {
  id                  String        @id @default(uuid())
  buildingId          String
  status              ProjectStatus @default(INITIATED)
  campaignId          String?
  contractorId        String?
  contractValue       Decimal?
  commissionAmount    Decimal?
  altumApplicationRef String?
  createdAt           DateTime      @default(now())

  building   Building        @relation(fields: [buildingId], references: [id])
  campaign   VotingCampaign? @relation(fields: [campaignId], references: [id])
  contractor Contractor?     @relation(fields: [contractorId], references: [id])
}

// ─── OPEN DATA SYNC MODELS ────────────────────────────────────

// VZD apartment transaction prices — synced from tg_darjumi CSV (data.gov.lv)
// Source: https://data.gov.lv/dati/lv/dataset/darijumi-ar-telpu-grupam
// CSV field mapping: DeaId, ObjType, ProCadNr, Std, ArDistrict, ArCity, ArParish,
//   DeaDate (YYYY-MM-DD), DeaAmount, BuiCadNr, BuiTotalArea, BuiExploitYear,
//   MaterialKind, Deprecation, PregCadNr, PregFloorMin, PregFloorMax, PregTotalArea
model ApartmentTransaction {
  id              String   @id @default(uuid())
  deaId           Int      @unique
  objType         String
  propertyCadNr   String
  buildingCadNr   String?
  address         String
  district        String?
  city            String?
  transactionDate DateTime
  priceEur        Decimal
  buildingAreaM2  Decimal?
  buildingYear    Int?
  wallMaterial    String?
  depreciation    String?
  apartmentCadNr  String?
  floorMin        Int?
  floorMax        Int?
  apartmentAreaM2 Decimal?
  syncedAt        DateTime @default(now())

  // Logical reference to Building.cadastralCode — no FK constraint (independent sync)
  @@index([buildingCadNr])
  @@index([city])
  @@index([transactionDate])
  @@index([buildingYear])
}

// VZD cadastral values — synced annually from data.gov.lv
// Source: https://data.gov.lv/dati/dataset/fiskalas-un-universalas-kadastralas-vertibas-uz-2025-gada-1-janvari
model CadastralValue {
  id                String   @id @default(uuid())
  cadastralNr       String
  objectType        String
  fiscalValueEur    Decimal?
  universalValueEur Decimal?
  validFrom         DateTime
  syncedAt          DateTime @default(now())

  @@unique([cadastralNr, validFrom])
  @@index([cadastralNr])
}

// CSP house price and construction cost indices
// Source: stat.gov.lv API
model PriceIndex {
  id            String   @id @default(uuid())
  indexType     String   // HOUSE_PRICE | CONSTRUCTION_COST
  region        String?
  periodYear    Int
  periodQuarter Int?
  periodMonth   Int?
  value         Decimal
  syncedAt      DateTime @default(now())

  @@unique([indexType, region, periodYear, periodQuarter, periodMonth])
  @@index([indexType, periodYear])
}

// SPRK utility tariffs — manually seeded and updated per regulatory decisions
// Source: sprk.gov.lv
model UtilityTariff {
  id           String    @id @default(uuid())
  providerName String
  city         String
  tariffType   String    // HEATING | COLD_WATER | WASTEWATER
  pricePerUnit Decimal
  unit         String    // EUR/MWh | EUR/m3
  validFrom    DateTime
  validTo      DateTime?
  sourceUrl    String?
  updatedAt    DateTime  @updatedAt

  @@unique([providerName, tariffType, validFrom])
  @@index([city, tariffType])
}

// Building series reference — static seed from academic sources
// No official registry exists; heuristic match via year + material + floors
model BuildingSeries {
  code              String  @id
  wallMaterialKey   String
  floorsMin         Int?
  floorsMax         Int?
  yearFrom          Int
  yearTo            Int
  typicalAreaM2     Decimal?
  description       String?
}
