generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum EnergyClass {
  A
  B
  C
  D
  E
  F
  G
}

enum ExpenseCategory {
  HEATING
  COLD_WATER
  HOT_WATER
  WASTEWATER
  WASTE
  CLEANING
  REPAIR_FUND
  ADMINISTRATION
  ELEVATOR
  OTHER
}

enum UserRole {
  OWNER
  BOARD_MEMBER
  PROFESSIONAL
  ASSOCIATION_ADMIN
  CONTRACTOR
  PLATFORM_ADMIN
}

enum Language {
  LV
  RU
}

enum ReportStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum VoteDecision {
  YES
  NO
  ABSTAIN
}

enum AuthMethod {
  SMART_ID
  EPARAKSTS
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  INITIATED
  VOTING
  CONTRACTED
  IN_PROGRESS
  COMPLETED
}

// v2 enums — Readiness Platform

enum FundingWindowStatus {
  CLOSED
  EXPECTED
  OPEN
  UNKNOWN
}

enum DataConfidence {
  PUBLIC_DATA
  USER_UPLOADED
  BOARD_VERIFIED
  PROFESSIONAL_VERIFIED
}

enum LegalConfidence {
  DRAFT
  NEEDS_REVIEW
  VALIDATED
}

enum BuildingProjectStatus {
  NOT_READY
  READY_FOR_LOAN
  READY_FOR_FUTURE_GRANT
  IN_APPLICATION
  APPROVED
  IN_CONSTRUCTION
  COMPLETED
}

enum DecisionType {
  PREPARATION_DECISION
  REPRESENTATIVE_AUTHORIZATION
  DATA_COLLECTION_CONSENT
  ENERGY_AUDIT_DECISION
  PROGRAM_APPLICATION_DECISION
  LOAN_DECISION
  SUPPLIER_SELECTION_DECISION
}

enum FinancingScenarioType {
  SCF_2026_2032
  ALTUM_REMONTA_AIZDEVUMS
  COMMERCIAL_BANK
  OWN_FUND
  MIXED
}

enum FinancingEligibility {
  ELIGIBLE
  LIKELY_ELIGIBLE
  UNLIKELY
  NOT_ELIGIBLE
  UNKNOWN
}

enum ContractorSubscriptionTier {
  NONE
  BASIC
  PLUS
}

enum BuildingDocumentType {
  ENERGY_CERTIFICATE
  TECHNICAL_PASSPORT
  TECHNICAL_INSPECTION
  OWNER_LIST
  ASSOCIATION_DOCUMENTS
  POWER_OF_ATTORNEY
  OWNER_DECISIONS
  GDPR_CONSENTS
}

// ─── MODELS ───────────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  phone             String?
  fullName          String   @default("")
  role              UserRole @default(OWNER)
  smartIdCode       String?
  preferredLanguage Language @default(LV)
  createdAt         DateTime @default(now())

  apartments      Apartment[]
  votes           Vote[]
  uploadedReports ExpenseReport[]

  // NextAuth required fields
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Building {
  id               String       @id @default(uuid())
  address          String
  cadastralCode    String       @unique
  vzdId            String?      @unique
  series           String?
  constructionYear Int?
  totalAreaM2      Decimal?
  apartmentCount   Int?
  floorCount       Int?
  wallMaterial     String?
  energyClass      EnergyClass?
  district         String?
  lat              Decimal?
  lon              Decimal?
  vzdUpdatedAt         DateTime?
  bvkbUpdatedAt        DateTime?
  postalCode           String?   // from VAR ATRIB[9]; e.g. "LV-1050"
  isPlanAddress        Boolean?  // from VAR PLAN_ADR[15]; true=planned/unlinked, false=real building
  heatingEnergyKwhM2   Decimal?  // from BVKB[20]: heat consumption kWh/m²/year (pre-renovation baseline)
  renovationYear       Int?      // from BVKB[14]: year building was renovated (null = not renovated)
  bvkbCertDate         DateTime? // from BVKB[3]: energy certificate issue date
  primaryEnergyKwhM2   Decimal?  // from BVKB[27]: total primary energy kWh/m²/year
  co2KgM2              Decimal?  // from BVKB[34]: CO2 emissions kg/m²/year
  // Issue #106: board-set average repair fund contribution per apartment per month
  avgRepairFundEurPerApt Decimal?
  // Issue #114: data verification flags set by board/professional action
  boardVerified        Boolean   @default(false)
  professionalVerified Boolean   @default(false)
  // Issue #119: owner list staleness tracking
  ownerListUpdatedAt   DateTime?
  ownerListCount       Int?
  createdAt            DateTime  @default(now())

  apartments        Apartment[]
  reports           ExpenseReport[]
  campaigns         VotingCampaign[]
  projects          RenovationProject[]
  readinessScore    BuildingReadinessScore?
  scenarios         FinancingScenario[]
  decisionCampaigns DecisionCampaign[]
  readinessOrders   ReadinessReportOrder[]
  documents         BuildingDocument[]

  @@index([district])
  @@index([series])
  @@index([energyClass])
  @@index([constructionYear])
  @@index([wallMaterial])
}

model Apartment {
  id              String   @id @default(uuid())
  buildingId      String
  apartmentNumber String
  areaM2          Decimal
  ownerId         String?
  ownershipShare  Decimal
  zemesgramataRef String?

  building Building  @relation(fields: [buildingId], references: [id])
  owner    User?     @relation(fields: [ownerId], references: [id])
  votes    Vote[]

  @@unique([buildingId, apartmentNumber])
}

model ExpenseReport {
  id          String       @id @default(uuid())
  buildingId  String
  periodYear  Int
  periodMonth Int
  rawFileKey      String
  parsedData      Json?
  status          ReportStatus @default(PENDING)
  uploadedBy      String?
  processedAt     DateTime?
  // Issue #109: retention — raw file deleted after parse; set by cleanup job
  rawFileDeletedAt DateTime?
  // Issue #117: AI parse confidence level ('low' | 'medium' | 'high')
  parseConfidence  String       @default("medium")
  createdAt       DateTime     @default(now())

  building Building      @relation(fields: [buildingId], references: [id])
  uploader User?         @relation(fields: [uploadedBy], references: [id])
  items    ExpenseItem[]

  @@unique([buildingId, periodYear, periodMonth])
  @@index([buildingId])
}

model ExpenseItem {
  id           String          @id @default(uuid())
  reportId     String
  category     ExpenseCategory
  rawLabel     String
  amountTotal  Decimal
  amountPerM2  Decimal
  amountPerApt Decimal
  unit         String?

  report ExpenseReport @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([category])
}

model BenchmarkSegment {
  id            String          @id @default(uuid())
  series        String
  district      String
  areaRange     String
  category      ExpenseCategory
  periodYear    Int
  periodMonth   Int
  buildingCount Int
  p25           Decimal
  p50           Decimal
  p75           Decimal
  computedAt    DateTime        @default(now())

  @@unique([series, district, areaRange, category, periodYear, periodMonth])
}

model VotingCampaign {
  id                String         @id @default(uuid())
  buildingId        String
  title             String
  description       String?
  status            CampaignStatus @default(DRAFT)
  requiredThreshold Decimal        @default(0.50)
  currentYesShare   Decimal        @default(0)
  deadline          DateTime?
  protocolKey       String?
  createdAt         DateTime       @default(now())

  building         Building            @relation(fields: [buildingId], references: [id])
  votes            Vote[]
  projects         RenovationProject[]
  decisionCampaign DecisionCampaign?

  @@index([buildingId])
}

model Vote {
  id             String       @id @default(uuid())
  campaignId     String
  apartmentId    String
  ownerId        String
  decision       VoteDecision
  ownershipShare Decimal
  signature      String
  signedAt       DateTime
  authMethod     AuthMethod

  campaign  VotingCampaign @relation(fields: [campaignId], references: [id])
  apartment Apartment      @relation(fields: [apartmentId], references: [id])
  owner     User           @relation(fields: [ownerId], references: [id])

  @@unique([campaignId, apartmentId])
  @@index([campaignId])
}

model Contractor {
  id                    String                     @id @default(uuid())
  userId                String                     @unique
  companyName           String
  registrationNumber    String                     @unique
  luroftVerified        Boolean                    @default(false)
  specializations       String[]
  geographicCoverage    String[]
  rating                Decimal?
  ratingCount           Int                        @default(0)
  active                Boolean                    @default(true)
  subscriptionTier      ContractorSubscriptionTier @default(NONE)
  subscriptionStartedAt DateTime?
  subscriptionExpiresAt DateTime?
  createdAt             DateTime                   @default(now())

  projects RenovationProject[]
}


model RenovationProject {
  id                  String        @id @default(uuid())
  buildingId          String
  status              ProjectStatus @default(INITIATED)
  campaignId          String?
  contractorId        String?
  contractValue       Decimal?
  altumApplicationRef String?
  // Issue #107: count of received contractor offers (bids) for procurement transparency score
  offerCount          Int           @default(0)
  createdAt           DateTime      @default(now())

  building   Building        @relation(fields: [buildingId], references: [id])
  campaign   VotingCampaign? @relation(fields: [campaignId], references: [id])
  contractor Contractor?     @relation(fields: [contractorId], references: [id])
}

// Issue #105: building document checklist — tracks which of the 8 required
// documents have been uploaded, replacing the PDF-report-count proxy.
model BuildingDocument {
  id           String              @id @default(uuid())
  buildingId   String
  documentType BuildingDocumentType
  fileKey      String?
  uploadedAt   DateTime            @default(now())
  uploadedBy   String?
  expiresAt    DateTime?

  building Building @relation(fields: [buildingId], references: [id])

  @@unique([buildingId, documentType])
  @@index([buildingId])
}

// ─── v2 READINESS PLATFORM MODELS ─────────────────────────────

model BuildingReadinessScore {
  id                          String          @id @default(uuid())
  buildingId                  String          @unique
  energyScore                 Int?
  fundingEligibilityScore     Int?
  documentReadinessScore      Int?
  ownerDecisionReadinessScore Int?
  financialFeasibilityScore   Int?
  supplierSelectionStatus     String?
  legalConfidenceStatus       LegalConfidence @default(DRAFT)
  dataConfidenceStatus        DataConfidence  @default(PUBLIC_DATA)
  nextBestAction              String
  nextBestActionRu            String?
  procurementTransparencyScore Int?
  supplierConflictRisk        Int?
  decisionQuality             Int?
  ownerUnderstandingScore     Int?
  documentCompleteness        Int?
  priceBenchmarkDeviation     Decimal?
  rulesEngineVersion          String
  computedAt                  DateTime        @default(now())
  expiresAt                   DateTime?

  building Building @relation(fields: [buildingId], references: [id])

  @@index([buildingId])
}

model FinancingScenario {
  id                         String                @id @default(uuid())
  buildingId                 String
  scenarioType               FinancingScenarioType
  windowStatus               FundingWindowStatus
  eligibility                FinancingEligibility
  confidence                 String
  estimatedCostEur           Decimal?
  estimatedSubsidyPercent    Decimal?
  estimatedSubsidyEur        Decimal?
  monthlyPaymentPerApartment Decimal?
  paybackYears               Decimal?
  reasoningLv                String
  reasoningRu                String?
  rulesEngineVersion         String
  computedAt                 DateTime              @default(now())

  building Building @relation(fields: [buildingId], references: [id])

  @@unique([buildingId, scenarioType])
  @@index([buildingId])
  @@index([scenarioType])
}

model DecisionCampaign {
  id                     String          @id @default(uuid())
  buildingId             String
  decisionType           DecisionType
  title                  String
  questionTextLv         String
  questionTextRu         String?
  explanationTextLv      String
  explanationTextRu      String?
  intentionsCollected    Boolean         @default(false)
  intentionsYesCount     Int             @default(0)
  intentionsNoCount      Int             @default(0)
  intentionsAbstainCount Int             @default(0)
  formalCampaignId       String?         @unique
  bisExportedAt          DateTime?
  bisExportRef           String?
  legalConfidence        LegalConfidence @default(DRAFT)
  status                 CampaignStatus  @default(DRAFT)
  deadline               DateTime?
  createdAt              DateTime        @default(now())

  building       Building        @relation(fields: [buildingId], references: [id])
  formalCampaign VotingCampaign? @relation(fields: [formalCampaignId], references: [id])

  @@index([buildingId])
  @@index([decisionType])
}

model ReadinessReportOrder {
  id                 String   @id @default(uuid())
  buildingId         String
  orderedByEmail     String
  orderedByUserId    String?
  amountEur          Decimal
  currency           String   @default("EUR")
  paymentProviderRef String?
  paymentStatus      String   @default("pending")
  reportFileKey      String?
  emailSentAt        DateTime?
  language           Language @default(LV)
  createdAt          DateTime @default(now())
  paidAt             DateTime?

  building Building @relation(fields: [buildingId], references: [id])

  @@index([buildingId])
  @@index([orderedByEmail])
}

model RulesEngineVersion {
  version         String                @id
  scenarioType    FinancingScenarioType
  rulesJson       Json
  effectiveFrom   DateTime
  effectiveUntil  DateTime?
  description     String?
  createdAt       DateTime              @default(now())
  createdByUserId String?

  @@index([scenarioType, effectiveFrom])
}

// ─── OPEN DATA SYNC MODELS ────────────────────────────────────

// VZD apartment transaction prices — synced from tg_darjumi CSV (data.gov.lv)
// Source: https://data.gov.lv/dati/lv/dataset/darijumi-ar-telpu-grupam
// CSV field mapping: DeaId, ObjType, ProCadNr, Std, ArDistrict, ArCity, ArParish,
//   DeaDate (YYYY-MM-DD), DeaAmount, BuiCadNr, BuiTotalArea, BuiExploitYear,
//   MaterialKind, Deprecation, PregCadNr, PregFloorMin, PregFloorMax, PregTotalArea
model ApartmentTransaction {
  id              String   @id @default(uuid())
  deaId           Int      @unique
  objType         String
  propertyCadNr   String
  buildingCadNr   String?
  address         String
  district        String?
  city            String?
  transactionDate DateTime
  priceEur        Decimal
  buildingAreaM2  Decimal?
  buildingYear    Int?
  wallMaterial    String?
  depreciation    String?
  apartmentCadNr  String?
  floorMin        Int?
  floorMax        Int?
  apartmentAreaM2 Decimal?
  syncedAt        DateTime @default(now())
  buildingUseCode String?  // from tg_darjumi BUI_USE_CODE[20]; 1122=multi-apartment building

  // Logical reference to Building.cadastralCode — no FK constraint (independent sync)
  @@index([buildingCadNr])
  @@index([city])
  @@index([transactionDate])
  @@index([buildingYear])
}

// VZD cadastral values — synced annually from data.gov.lv
// Source: https://data.gov.lv/dati/dataset/fiskalas-un-universalas-kadastralas-vertibas-uz-2025-gada-1-janvari
model CadastralValue {
  id                String   @id @default(uuid())
  cadastralNr       String
  objectType        String
  fiscalValueEur    Decimal?
  universalValueEur Decimal?
  validFrom         DateTime
  syncedAt          DateTime @default(now())

  @@unique([cadastralNr, validFrom])
  @@index([cadastralNr])
}

// CSP house price and construction cost indices
// Source: stat.gov.lv API
model PriceIndex {
  id            String   @id @default(uuid())
  indexType     String   // HOUSE_PRICE | CONSTRUCTION_COST
  region        String?
  periodYear    Int
  periodQuarter Int?
  periodMonth   Int?
  value         Decimal
  syncedAt      DateTime @default(now())

  @@unique([indexType, region, periodYear, periodQuarter, periodMonth])
  @@index([indexType, periodYear])
}

// SPRK utility tariffs — manually seeded and updated per regulatory decisions
// Source: sprk.gov.lv
model UtilityTariff {
  id           String    @id @default(uuid())
  providerName String
  city         String
  tariffType   String    // HEATING | COLD_WATER | WASTEWATER
  pricePerUnit Decimal
  unit         String    // EUR/MWh | EUR/m3
  validFrom    DateTime
  validTo      DateTime?
  sourceUrl    String?
  updatedAt    DateTime  @updatedAt

  @@unique([providerName, tariffType, validFrom])
  @@index([city, tariffType])
}

// Building series reference — static seed from academic sources
// No official registry exists; heuristic match via year + material + floors
model BuildingSeries {
  code            String   @id
  wallMaterialKey String
  floorsMin       Int?
  floorsMax       Int?
  yearFrom        Int
  yearTo          Int
  typicalAreaM2   Decimal?
  description     String?
}

// Apartment-level records from VZD PremiseGroup data (PremiseGroupItemData elements)
// Source: https://data.gov.lv/dati/dataset/kadastra-informacijas-sistemas-atvertie-dati
// XSD: PremiseGroupFullData.xsd — tag PremiseGroupCadastreNr is 17 chars; first 14 = building cadastralCode
// Linked to Building via buildingCadastralCode — no FK constraint (independent sync schedule)
model BuildingUnit {
  id                    String   @id @default(uuid())
  cadastralCode         String   @unique  // PremiseGroupCadastreNr (17 chars)
  buildingCadastralCode String            // first 14 chars of cadastralCode → Building.cadastralCode
  varisCode             String?           // VARISCode (VAR apartment address code)
  useKindId             Int?              // PremiseGroupUseKindId; 1122 = residential apartment
  areaM2                Decimal?          // PremiseGroupArea m²
  floor                 Int?              // PremiseGroupFloor
  roomCount             Int?              // PremiseGroupRoomsCount (if present in XML)
  syncedAt              DateTime @default(now())

  @@index([buildingCadastralCode])
}

// Heating energy norms by building series — seeded from verified research data
// Source: ALTUM program portfolio (627 buildings), University of Latvia, Ministry of Economics Latvia 2023
// Used for benchmark comparison on building page and audit report
model BuildingSeriesBenchmark {
  seriesCode              String   @id   // "103", "316", "467", "NATIONAL_AVERAGE", etc.
  heatingKwhM2Year        Decimal        // pre-renovation heating norm kWh/m²/year
  hotWaterKwhM2Year       Decimal?       // hot water norm kWh/m²/year (null = use national average)
  afterRenovationTargetKwhM2Year Decimal? // target after renovation (~50-54 kWh/m²/year)
  sourceDescription       String         // citation / source
  updatedAt               DateTime @updatedAt
}
