# ── Local dev ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# For production: copy to .env.production on the VPS (never commit).

# Database
# Local dev:  postgresql://postgres:postgres@localhost:5433/alteko  (Docker maps 5433→5432)
# Production: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/alteko
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/alteko"

# PostgreSQL credentials (used by docker-compose.yml in production)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-strong-password-in-production"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-min-32-chars"

# Email (magic link + transactional)
# Local dev: use Mailhog (docker-compose.db.yml) — no auth, catches all emails
#   docker compose -f docker-compose.db.yml up -d mailhog
#   View emails: http://localhost:8025
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1025"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="ALTEKO Dev <dev@alteko.lv>"
# Production: replace with real SMTP (Resend, SendGrid, etc.)
# EMAIL_SERVER_HOST="smtp.resend.com"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="resend"
# EMAIL_SERVER_PASSWORD="re_..."
# EMAIL_FROM="ALTEKO <noreply@alteko.lv>"

# Admin notification email (receives new order alerts)
ADMIN_EMAIL="admin@alteko.lv"

# OpenAI
OPENAI_API_KEY="sk-..."

# S3 / Object Storage
# Local dev: use MinIO (docker-compose.db.yml) — port 9100 (9000 may be occupied)
#   docker compose -f docker-compose.db.yml up -d minio
#   docker run --rm --network alteko_default --entrypoint /bin/sh minio/mc:latest \
#     -c "mc alias set local http://minio:9000 minioadmin minioadmin && mc mb --ignore-existing local/alteko-local"
#   Web console: http://localhost:9101  (minioadmin / minioadmin)
S3_ENDPOINT="http://localhost:9100"
S3_REGION="us-east-1"
S3_BUCKET="alteko-local"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
# Production: replace with real S3/Cloudflare R2/Hetzner Object Storage
# S3_ENDPOINT="https://s3.eu-central-1.amazonaws.com"
# S3_REGION="eu-central-1"
# S3_BUCKET="alteko-prod"
# S3_ACCESS_KEY_ID="AKIA..."
# S3_SECRET_ACCESS_KEY="..."

# External APIs
JANA_SETA_API_URL="https://api.kartes.lv"
JANA_SETA_API_KEY="..."
LVM_GEOSERVER_URL="https://lvmgeoserver.lvm.lv/geoserver/publicwfs/wfs"

# Data sync — all sources are CC-BY-4.0 from data.gov.lv
# Building.ZIP — real cadastral codes, year, material, floors (~500k buildings, weekly)
VZD_BUILDING_ZIP_URL="https://data.gov.lv/dati/dataset/be841486-4af9-4d38-aa14-6502a2ddb517/resource/9fe29b57-07cd-4458-b22c-b0b9f2bc8915/download/building.zip"
# VAR address register — addresses and coordinates, updated daily
VZD_DATA_URL="https://data.gov.lv/dati/dataset/6b06a7e8-dedf-4705-a47b-2a7c51177473/resource/a510737a-18ce-400f-ad4b-04fce5228272/download/aw_eka.csv"
# BVKB energy certificates — filename includes date; update when VZD publishes a new file
# Dataset page: https://data.gov.lv/dati/eng/dataset/bis_ygdi8jmgg-bneuijz7wiwq
BVKB_DATA_URL="https://data.gov.lv/dati/dataset/075498f5-0136-47d7-af86-0066acb0264c/resource/212c0946-a06e-4c2c-8112-833b2969b44b/download/eku-energosertifikati-02.05.2026.csv"
# Cadastral values — fiscal + universal values (annual, ~1 January each year)
# Dataset: https://data.gov.lv/dati/dataset/fiskalas-un-universalas-kadastralas-vertibas-uz-2025-gada-1-janvari
# Update this URL each year when VZD publishes the new file.
VZD_CADASTRAL_VALUES_URL=""
# PremiseGroup.ZIP — apartment-level cadastral data (separate file, same dataset as Building.ZIP)
# Dataset: https://data.gov.lv/dati/dataset/kadastra-informacijas-sistemas-atvertie-dati
# If unset, sync-premises.ts falls back to VZD_BUILDING_ZIP_URL — Building.ZIP contains PremiseGroup XML,
# so this variable is OPTIONAL. The sync works without it.
# To use a separate download: find "Telpu grupu raksturojošie dati" resource on the dataset page above.
VZD_PREMISE_GROUP_URL=""
# VZD apartment transaction prices (tg_darjumi) — full history 2016–present (~200MB)
# Dataset page: https://data.gov.lv/dati/lv/dataset/darijumi-ar-telpu-grupam
VZD_TRANSACTIONS_URL="https://data.gov.lv/dati/dataset/ab6b043f-9824-4f7f-afa2-c97d3cb1ed4b/resource/ee3a262f-dfc2-4e87-b74b-440629ee1e31/download/tg_darjumi_01012016-31032026.csv"

# Optional
SKIP_ENV_VALIDATION="false"
# Set to "true" to keep downloaded temp files after sync (for debugging)
KEEP_TEMP_FILES="false"

# Payload CMS
PAYLOAD_SECRET="change-me-min-32-chars-random-string"
